#!/usr/bin/env bash
# Optional update notice. This file and hooks.json can be deleted without affecting Superleads.
# It performs one anonymous GET of a public manifest, writes nothing, and fails silently.

case "${SUPERLEADS_DISABLE_UPDATE_CHECK:-}" in
  1|true|TRUE|yes|YES|on|ON) exit 0 ;;
esac

case "${DISABLE_TELEMETRY:-}" in
  1|true|TRUE|yes|YES|on|ON) exit 0 ;;
esac

plugin_root="${CLAUDE_PLUGIN_ROOT:-$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)}"
local_manifest="$plugin_root/.codex-plugin/plugin.json"

[ -r "$local_manifest" ] || exit 0
command -v curl >/dev/null 2>&1 || exit 0

local_version=$(sed -n 's/^[[:space:]]*"version"[[:space:]]*:[[:space:]]*"\([0-9][0-9.]*\)".*/\1/p' "$local_manifest" | head -n 1)
[ -n "$local_version" ] || exit 0

remote_manifest=$(curl --fail --silent --show-error --max-time 3 \
  https://raw.githubusercontent.com/fleixweb/superleads/master/.codex-plugin/plugin.json 2>/dev/null) || exit 0
remote_version=$(printf '%s\n' "$remote_manifest" | sed -n 's/^[[:space:]]*"version"[[:space:]]*:[[:space:]]*"\([0-9][0-9.]*\)".*/\1/p' | head -n 1)
[ -n "$remote_version" ] || exit 0

version_is_newer() {
  local remote_major remote_minor remote_patch
  local local_major local_minor local_patch

  IFS=. read -r remote_major remote_minor remote_patch <<< "$1"
  IFS=. read -r local_major local_minor local_patch <<< "$2"

  [ "$remote_major" -gt "$local_major" ] && return 0
  [ "$remote_major" -lt "$local_major" ] && return 1
  [ "$remote_minor" -gt "$local_minor" ] && return 0
  [ "$remote_minor" -lt "$local_minor" ] && return 1
  [ "$remote_patch" -gt "$local_patch" ]
}

if version_is_newer "$remote_version" "$local_version"; then
  printf 'Superleads %s 可用（你在 %s）-> 见 CHANGELOG\n' "$remote_version" "$local_version"
fi
