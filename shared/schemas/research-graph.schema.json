{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superleads.local/schemas/research-graph.schema.json",
  "title": "Superleads Research Graph",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "CandidateSignalItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "source_label": {"type": ["string", "null"]},
        "source_url": {
          "type": ["string", "null"],
          "description": "When non-empty, runtime validation requires is_safe_public_http_url()."
        },
        "observed_at": {"type": ["string", "null"]},
        "period": {"type": ["string", "null"]},
        "locator": {"type": ["string", "null"]}
      }
    },
    "CandidateSignalState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["observed", "not_observed", "not_searched", "identity_pending", "source_restricted"]
        },
        "items": {
          "type": "array",
          "items": {"$ref": "#/$defs/CandidateSignalItem"}
        },
        "searched_scopes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "properties": {
    "runs": {
      "type": "array",
      "items": {
        "$ref": "run.schema.json"
      }
    },
    "briefs": {
      "type": "array",
      "items": {
        "$ref": "brief.schema.json"
      }
    },
    "plans": {
      "type": "array",
      "items": {
        "$ref": "plan.schema.json"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "name": {"type": ["string", "null"]},
          "company_name": {"type": ["string", "null"]},
          "entity_id": {"type": ["string", "null"]},
          "website": {
            "type": ["string", "null"],
            "description": "When non-empty, runtime validation requires a safe public HTTP(S) URL or plain public domain."
          },
          "domain": {"type": ["string", "null"]},
          "country_or_region": {"type": ["string", "null"]},
          "source_hint": {"type": ["string", "null"]},
        "source_url": {
          "type": ["string", "null"],
          "description": "When non-empty, runtime validation requires is_safe_public_http_url()."
        },
          "status": {"type": ["string", "null"]},
          "note": {"type": ["string", "null"]},
          "run_id": {"type": ["string", "null"]},
          "brief_id": {"type": ["string", "null"]},
          "plan_id": {"type": ["string", "null"]},
          "discovery_method": {"type": ["string", "null"], "enum": ["search_web", "user_provided", "manual", "other", null]},
          "search_log_id": {"type": ["string", "null"]},
          "search_log_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "discovery_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label"],
              "properties": {
                "label": {"type": "string", "minLength": 1},
                "url": {
                  "type": ["string", "null"],
                  "description": "When non-empty, runtime validation requires is_safe_public_http_url()."
                },
                "source_type": {"type": ["string", "null"]},
                "search_log_id": {"type": ["string", "null"]},
                "source_id": {"type": ["string", "null"]},
                "observation_id": {"type": ["string", "null"]}
              }
            }
          },
          "dedupe_basis": {
            "type": "array",
            "items": {"type": "string"}
          },
          "business_relevance_status": {
            "type": ["string", "null"],
            "enum": [
              "directly_related",
              "possibly_related",
              "explicitly_excluded_or_unrelated",
              "identity_pending",
              "insufficient_information",
              null
            ]
          },
          "business_relevance_basis": {
            "type": "array",
            "items": {"type": "string"}
          },
          "business_relevance_notes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "identity_resolution_status": {
            "type": ["string", "null"],
            "enum": ["matched", "pending", "conflicted", "unresolved", "not_applicable", null]
          },
          "identity_resolution_basis": {
            "type": "array",
            "items": {"type": "string"}
          },
          "observed_business_signals": {
            "type": "array",
            "items": {"type": "string"}
          },
          "excluded_or_conflicting_signals": {
            "type": "array",
            "items": {"type": "string"}
          },
          "unknowns": {
            "type": "array",
            "items": {"type": "string"}
          },
          "source_restrictions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "next_verification_steps": {
            "type": "array",
            "items": {"type": "string"}
          },
          "signal_summary": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "business_match": {"$ref": "#/$defs/CandidateSignalState"},
              "website_contact": {"$ref": "#/$defs/CandidateSignalState"},
              "trade_record": {"$ref": "#/$defs/CandidateSignalState"},
              "china_relation": {"$ref": "#/$defs/CandidateSignalState"},
              "product_description_or_hs": {"$ref": "#/$defs/CandidateSignalState"}
            }
          }
          }
        },
        "allOf": [
          {
            "if": {"properties": {"discovery_method": {"const": "search_web"}}, "required": ["discovery_method"]},
            "then": {
              "required": ["run_id", "brief_id", "plan_id"],
              "anyOf": [
                {"required": ["search_log_id"]},
                {"required": ["search_log_ids"]}
              ]
            }
          }
        ]
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "source-observation.schema.json#/$defs/Source"
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "source-observation.schema.json#/$defs/Observation"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entity_id"
        ],
        "properties": {
          "entity_id": {
            "type": "string"
          },
          "name": {
            "type": ["string", "null"]
          },
          "legal_name": {"type": ["string", "null"]},
          "website": {
            "type": ["string", "null"],
            "description": "When non-empty, runtime validation requires a safe public HTTP(S) URL or plain public domain."
          },
          "domain": {
            "type": ["string", "null"],
            "description": "When non-empty, runtime validation requires a safe public HTTP(S) URL or plain public domain."
          },
          "country_or_region": {"type": ["string", "null"]},
          "customer_type": {"type": ["string", "null"]}
          }
        }
    },
    "entity_relationships": {
      "type": "array",
      "items": {
        "$ref": "entity-relationship.schema.json"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "entity_id",
          "claim_type",
          "subject",
          "predicate",
          "typed_value",
          "support_status"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "entity_id": {
            "type": "string"
          },
          "claim_type": {
            "type": "string",
            "enum": [
              "product_match",
              "company_identity",
              "contact_route",
              "location",
              "registration",
              "brand_trademark",
              "channel_role",
              "ownership",
              "certification"
            ]
          },
          "subject": {
            "type": "string"
          },
          "predicate": {
            "type": "string"
          },
          "typed_value": {},
          "as_of": {
            "type": [
              "string",
              "null"
            ]
          },
          "claim_scope": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "current_source",
              "source_snapshot",
              "point_in_time",
              "unknown",
              null
            ]
          },
          "support_status": {
            "type": "string"
          },
          "contradiction_status": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "claim_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_evidence_id",
          "claim_id",
          "observation_id",
          "relation",
          "directness",
          "source_authority",
          "independence_group",
          "freshness",
          "excerpt_pointer",
          "claim_field_anchors"
        ],
        "properties": {
          "claim_evidence_id": {
            "type": "string"
          },
          "claim_id": {
            "type": "string"
          },
          "observation_id": {
            "type": "string"
          },
          "relation": {
            "type": "string",
            "enum": [
              "supports",
              "contradicts",
              "contextual"
            ]
          },
          "directness": {"type": "string", "minLength": 1},
          "source_authority": {"type": "string", "minLength": 1},
          "independence_group": {"type": "string", "minLength": 1},
          "freshness": {"type": "string", "minLength": 1},
          "excerpt_pointer": {"type": "string", "minLength": 1}
          ,"claim_field_anchors": {
            "type": "object",
            "additionalProperties": false,
            "required": ["subject", "predicate", "claim_type", "typed_value"],
            "properties": {
              "subject": {"type": "string", "minLength": 1},
              "predicate": {"type": "string", "minLength": 1},
              "claim_type": {"type": "string", "minLength": 1},
              "typed_value": {"type": "string", "minLength": 1}
            }
          }
          }
        }
    },
    "contact_points": {
      "type": "array",
      "items": {
        "$ref": "contact-intelligence.schema.json#/$defs/ContactPoint"
      }
    },
    "contact_claims": {
      "type": "array",
      "items": {
        "$ref": "contact-intelligence.schema.json#/$defs/ContactClaim"
      }
    },
    "unassigned_contact_leads": {
      "type": "array",
      "items": {
        "$ref": "contact-intelligence.schema.json#/$defs/UnassignedContactLead"
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hypothesis_id",
          "entity_id",
          "basis_claim_ids",
          "hypothesis_text",
          "unknowns",
          "suggested_action",
          "next_verification_action"
        ],
        "properties": {
          "hypothesis_id": {
            "type": "string"
          },
          "entity_id": {
            "type": "string"
          },
          "basis_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "basis_contact_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hypothesis_text": {
            "type": "string"
          },
          "unknowns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "suggested_action": {
            "type": "string"
          },
          "next_verification_action": {
            "type": "string"
          },
          "expires_at": {"type": ["string", "null"]},
          "risk_notes": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assessment_id",
          "run_id",
          "entity_id",
          "brief_id",
          "disposition",
          "basis_claim_ids",
          "missing_requirements",
          "manual_review_required",
          "rationale_structured"
        ],
        "properties": {
          "assessment_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "entity_id": {
            "type": "string"
          },
          "brief_id": {
            "type": "string"
          },
          "disposition": {
            "type": "string",
            "enum": [
              "重点开发",
              "推荐跟进",
              "需人工核查",
              "暂不建议",
              "排除"
            ]
          },
          "basis_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missing_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "manual_review_required": {
            "type": "boolean"
          },
          "rationale_structured": {
            "type": "object",
            "additionalProperties": false,
            "required": ["basis_claim_ids"],
            "properties": {
              "basis_claim_ids": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "related_hypothesis_ids_for_outreach": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scope_decision_id": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "review_findings": {
      "type": "array",
      "items": {
        "$ref": "review-finding.schema.json"
      }
    },
    "audits": {
      "type": "array",
      "items": {
        "$ref": "audit.schema.json"
      }
    },
    "delivery_manifests": {
      "type": "array",
      "items": {
        "$ref": "delivery-manifest.schema.json"
      }
    },
    "search_logs": {
      "type": "array",
      "items": {
        "$ref": "search-log.schema.json"
      }
    },
    "review_attestations": {
      "type": "array",
      "items": {
        "$ref": "review-attestation.schema.json"
      }
    },
    "inquiries": {
      "type": "array",
      "items": {"$ref": "inquiry.schema.json"}
    },
    "mail_intake_rules": {
      "type": "array",
      "items": {"$ref": "mail-intake-rule.schema.json"}
    },
    "scope_decisions": {
      "type": "array",
      "items": {"$ref": "scope-decision.schema.json"}
    }
  },
  "required": [
    "runs",
    "briefs",
    "plans",
    "candidates"
  ]
}
