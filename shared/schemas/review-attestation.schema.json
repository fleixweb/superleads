{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superleads.local/schemas/review-attestation.schema.json",
  "title": "Superleads ReviewAttestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestation_id",
    "run_id",
    "brief_id",
    "plan_id",
    "review_cycle_id",
    "executor_actor_id",
    "execution_session_id",
    "reviewer_actor_id",
    "reviewer_session_id",
    "reviewed_at",
    "conclusion",
    "reviewed_entity_ids",
    "reviewed_assessment_ids",
    "input_graph_hash",
    "reviewed_subject_hash",
    "provenance_level"
  ],
  "properties": {
    "attestation_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "review_cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "executor_actor_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "execution_session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "reviewer_actor_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "reviewer_session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "conclusion": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "reviewed_entity_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewed_assessment_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_graph_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "reviewed_subject_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "provenance_level": {
      "type": "string",
      "enum": ["declared_separate_session"]
    }
  }
}
