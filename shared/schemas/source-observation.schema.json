{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superleads.local/schemas/source-observation.schema.json",
  "title": "Superleads Source and Observation",
  "$defs": {
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "publisher_relation",
        "provenance",
        "medium",
        "access_boundary"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_url": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^https?://"
        },
        "final_url": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^https?://"
        },
        "publisher_relation": {
          "type": "string",
          "enum": [
            "first_party",
            "third_party",
            "unknown"
          ]
        },
        "provenance": {
          "type": "string",
          "enum": [
            "discovered_public",
            "user_provided",
            "tool_enriched",
            "manual_input",
            "connected_account"
          ]
        },
        "medium": {
          "type": "string",
          "enum": [
            "website",
            "social",
            "registry",
            "directory",
            "map",
            "document",
            "spreadsheet",
            "image",
            "correspondence",
            "search_result"
          ]
        },
        "access_boundary": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\\\:\u0000-\u001F]+$",
          "not": {
            "pattern": "\\.\\."
          }
        },
        "artifact_media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9.+_-]*(/[A-Za-z0-9][A-Za-z0-9.+_-]*)?$"
        },
        "material_role": {
          "type": "string",
          "enum": [
            "published_source_copy",
            "user_business_dataset",
            "correspondence_export",
            "user_authored_note",
            "visual_reference",
            "connected_inbound_correspondence",
            "unknown"
          ]
        },
        "parent_source_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "message_id": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 512
        },
        "thread_id": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 512
        },
        "received_at": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "direction": {
          "type": ["string", "null"],
          "enum": ["inbound", "outbound", null]
        },
        "sender_literal": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 1024
        },
        "subject_literal": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 2048
        },
        "message_content_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "mailbox_ref": {
          "type": ["string", "null"],
          "pattern": "^[A-Za-z0-9._-]{1,128}$"
        },
        "mail_intake_rule_id": {
          "type": ["string", "null"],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "provenance": {
                "enum": [
                  "user_provided",
                  "manual_input",
                  "connected_account"
                ]
              }
            },
            "required": [
              "provenance"
            ]
          },
          "then": {
            "required": [
              "material_role"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "provenance": {
                "const": "user_provided"
              },
              "medium": {
                "enum": [
                  "document",
                  "spreadsheet",
                  "image",
                  "correspondence"
                ]
              }
            },
            "required": [
              "provenance",
              "medium"
            ]
          },
          "then": {
            "required": [
              "artifact_sha256",
              "artifact_name"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "provenance": {"const": "connected_account"},
              "medium": {"const": "correspondence"},
              "material_role": {"const": "connected_inbound_correspondence"}
            },
            "required": ["provenance", "medium", "material_role"]
          },
          "then": {
            "required": [
              "message_id", "received_at", "direction", "sender_literal",
              "subject_literal", "message_content_sha256", "mailbox_ref",
              "access_boundary"
            ],
            "properties": {
              "direction": {"const": "inbound"},
              "access_boundary": {"const": "read_only_connected_account"},
              "message_id": {"type": "string", "minLength": 1, "maxLength": 512},
              "received_at": {"type": "string", "minLength": 1},
              "sender_literal": {"type": "string", "minLength": 1, "maxLength": 1024},
              "subject_literal": {"type": "string", "minLength": 1, "maxLength": 2048},
              "message_content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "mailbox_ref": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,128}$"}
            }
          }
        },
        {
          "if": {
            "properties": {
              "provenance": {"const": "connected_account"},
              "medium": {"enum": ["document", "spreadsheet", "image"]}
            },
            "required": ["provenance", "medium"]
          },
          "then": {"required": ["parent_source_id", "artifact_sha256", "artifact_name"]}
        }
      ]
    },
    "Observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_id",
        "source_id",
        "capability",
        "concrete_tool",
        "observed_at",
        "access_status",
        "raw_excerpt",
        "extraction_method",
        "language",
        "translation_status"
      ],
      "properties": {
        "observation_id": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "entity_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "capability": {
          "type": "string",
          "enum": [
            "search.web",
            "source.open",
            "browser.render",
            "document.extract",
            "source.capture",
            "url.canonicalize",
            "entity.dedupe",
            "translate.text",
            "company.enrich",
            "email.verify",
            "domain.check",
            "social.visible.read",
            "registry.lookup",
            "trademark.lookup",
            "maps.lookup",
            "image.inspect",
            "mail.read",
            "memory.recall"
          ]
        },
        "concrete_tool": {
          "type": "string"
        },
        "observed_at": {
          "type": "string",
          "minLength": 1
        },
        "access_status": {
          "type": "string"
        },
        "http_status": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "raw_excerpt": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_or_dom_locator": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "extraction_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        },
        "translation_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "derived_from_observation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "snapshot_ref": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(artifact:sha256:[a-f0-9]{64}|mail:sha256:[a-f0-9]{64})#[^\\\\\u0000-\u001F]+$"
        },
        "observation_content_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "verbatim",
            "ocr_text",
            "visual_description",
            null
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "capability": {
                "const": "document.extract"
              }
            },
            "required": [
              "capability"
            ]
          },
          "then": {
            "properties": {
              "raw_excerpt": {
                "type": "string",
                "pattern": "\\S"
              },
              "content_hash": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "raw_excerpt",
              "content_hash"
            ]
          }
        },
        {
          "if": {
            "properties": {"capability": {"const": "mail.read"}},
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "raw_excerpt": {"type": "string", "pattern": "\\S"},
              "content_hash": {"type": "string", "minLength": 1},
              "snapshot_ref": {"type": "string", "pattern": "^mail:sha256:[a-f0-9]{64}#[^\\\\\u0000-\u001F]+$"}
            },
            "required": ["raw_excerpt", "content_hash", "snapshot_ref"]
          }
        }
        ,
        {
          "if": {
            "properties": {
              "capability": {
                "const": "image.inspect"
              }
            },
            "required": [
              "capability"
            ]
          },
          "then": {
            "properties": {
              "raw_excerpt": {
                "type": "string",
                "pattern": "\\S"
              },
              "content_hash": {
                "type": "string",
                "minLength": 1
              },
              "observation_content_kind": {
                "type": "string",
                "enum": [
                  "ocr_text",
                  "visual_description"
                ]
              }
            },
            "required": [
              "raw_excerpt",
              "content_hash",
              "observation_content_kind"
            ]
          }
        }
      ]
    }
  },
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/Source"
    },
    {
      "$ref": "#/$defs/Observation"
    }
  ]
}
